@model MvcMovie.Models.Entities.Student
@{
    ViewData["Title"]="Create";
}
<h1>Create</h1>
<h4>Student</h4>
<hr/>
<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="text" asp-for="FullName" placeholder="Nhập tên vào đây" />
    <span asp-validation-for="FullName"></span>
    <input type="text" asp-for="StudentCode" placeholder="Nhập msv vào đây" />
    <span asp-validation-for="StudentCode"></span>
    <input type="text" asp-for="Email" placeholder="Nhập email vào đây" />
    <span asp-validation-for="Email"></span>
    <div class="form-group">
        <label asp-for="FacultyID" class="control-label"></label>
        <select asp-for="FacultyID" class="form-control" asp-items="ViewBag.FacultyID"></select>
    </div>
    <input type="submit" value="send data"/>
</form>
@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}