@model MvcMovie.Models.Baithuchanh12.Device

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Device</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Device_ID" class="control-label"></label>
                <input asp-for="Device_ID" class="form-control" />
                <span asp-validation-for="Device_ID" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DeviceName" class="control-label"></label>
                <input asp-for="DeviceName" class="form-control" />
                <span asp-validation-for="DeviceName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Type_ID" class="control-label"></label>
                <div class="d-flex gap-2">
                <select onchange="fillTypeName(this)" asp-for="Type_ID" class="form-control"
                        asp-items="ViewBag.Type_Name" id="devicetypeSelect"></select>
                <button type="button" onclick="openDeviceTypePopup()" class="btn btn-success">+</button>
                <span asp-validation-for="Type_ID" class="text-danger"></span>
                </div>
            </div>
            <div class="form-group">
                <label class="control-label">TypeID</label>
                <input id="typeID" readonly class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="Remain" class="control-label"></label>
                <input asp-for="Remain" class="form-control" />
                <span asp-validation-for="Remain" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Cost" class="control-label"></label>
                <input asp-for="Cost" class="form-control" />
                <span asp-validation-for="Cost" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label class="control-label">Tên NCC</label>
                <div class="d-flex gap-2">

                    <select onchange="fillNcc(this)" asp-for="SupplierID" class="form-control"
                            asp-items="ViewBag.SupplierName" id="supplierSelect">
                    </select>

                    <button type="button" class="btn btn-success" onclick="openSupplierPopup()">
                        +
                    </button>

                </div>
    
            <div class="form-group">
                <label asp-for="SupplierID" class="control-label">Mã NCC</label>
                <input id="nccID" readonly class="form-control" />
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
        @*pop up của supplier*@
        <div id="supplierPopup" style="display:none;
            position:fixed;
            top:0;
            left:0;
            width:100%;
            height:100%;
            background:rgba(0,0,0,0.5);
            z-index:9999;">

            <div style="background:white;
                width:400px;
                padding:20px;
                margin:100px auto;
                border-radius:10px;">

                <h4>Thêm Supplier</h4>

                <div class="form-group">
                    <label>Mã NCC</label>
                    <input id="newSupplierID" class="form-control" />
                </div>

                <div class="form-group mt-2">
                    <label>Tên NCC</label>
                    <input id="newSupplierName" class="form-control" />
                </div>

                <div class="mt-3 d-flex gap-2">

                    <button class="btn btn-primary" onclick="saveSupplier()">
                        Lưu
                    </button>

                    <button class="btn btn-secondary" onclick="closeSupplierPopup()">
                        Hủy
                    </button>

                </div>

            </div>
        </div>

         @*pop up của devicetype*@
        <div id="devicetypePopup" style="display:none;
            position:fixed;
            top:0;
            left:0;
            width:100%;
            height:100%;
            background:rgba(0,0,0,0.5);
            z-index:999;">

            <div style="background:white;
                width:400px;
                padding:20px;
                margin:100px auto;
                border-radius:10px;">

                <h4>Thêm DeviceType</h4>

                <div class="form-group">
                    <label>TypeID</label>
                    <input id="newTypeID" class="form-control" />
                </div>

                <div class="form-group mt-2">
                    <label>TypeName</label>
                    <input id="newTypeName" class="form-control" />
                </div>

                <div class="mt-3 d-flex gap-2">

                    <button class="btn btn-primary" onclick="saveType()">
                        Lưu
                    </button>

                    <button class="btn btn-secondary" onclick="closeDeviceTypePopup()">
                        Hủy
                    </button>

                </div>

            </div>
        </div>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<script>
    
function openDeviceTypePopup() {

    document.getElementById("devicetypePopup").style.display = "block";
}

function closeDeviceTypePopup() {

    document.getElementById("devicetypePopup").style.display = "none";
}
function openSupplierPopup() {

    document.getElementById("supplierPopup").style.display = "block";
}

function closeSupplierPopup() {

    document.getElementById("supplierPopup").style.display = "none";
}
async function saveType(){
    let typeID=document.getElementById("newTypeID").value;
    let typeName=document.getElementById("newTypeName").value;
    let response = await fetch('/DeviceType/CreateAjax',{
        method: 'POST',
        headers:{
             'Content-Type': 'application/json'
        },
        body: JSON.stringify({
            Type_ID:typeID,
            TypeName:typeName
        })
    });
    let data = await response.json();
    if (data.success) {

        let select = document.getElementById("devicetypeSelect");

        let option = document.createElement("option");

        option.value = data.typeID;

        option.text = data.typeName;

        option.selected = true;

        select.appendChild(option);

        select.value = data.typeID;

        document.getElementById("typeID").value = data.typeID;

        closeDeviceTypePopup();
    }
    else {

        alert(data.message);
    }

}
async function saveSupplier() {

    let supplierID = document.getElementById("newSupplierID").value;

    let supplierName = document.getElementById("newSupplierName").value;

    let response = await fetch('/Supplier/CreateAjax', {

        method: 'POST',

        headers: {
            'Content-Type': 'application/json'
        },

        body: JSON.stringify({
            SupplierID: supplierID,
            SupplierName: supplierName
        })
    });

    let data = await response.json();

    if (data.success) {

        let select = document.getElementById("supplierSelect");

        let option = document.createElement("option");

        option.value = data.supplierID;

        option.text = data.supplierName;

        option.selected = true;

        select.appendChild(option);

        select.value = data.supplierID;

        document.getElementById("nccID").value = data.supplierID;

        closeSupplierPopup();
    }
    else {

        alert(data.message);
    }
}
    window.onload = function () {

        fillTypeName(document.querySelector("[name='Type_ID']"));
        fillNcc(document.querySelector('#supplierSelect'));

    };
    function fillTypeName(select) {
        document.getElementById("typeID").value = select.value;
    }
    function fillNcc(select) {
        document.getElementById("nccID").value = select.value;
    }

    
</script>