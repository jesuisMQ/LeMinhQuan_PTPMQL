@model MvcMovie.Models.ViewModels.ReceiptVM
@using MvcMovie.Models.Baithuchanh12
@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Receipt</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="SupplierID"></label>
                <select id="supplierSelect" asp-for="SupplierID" class="form-control" asp-items="ViewBag.SupplierID"></select>
                <button type="button" class="btn btn-success" onclick="openSupplierPopup()">
                        +
                    </button>
            </div>
            <h4>Hàng hóa:</h4>
            <div id="goodContainer">
            </div>
            <div class="form-group">
                <label asp-for="TimeStamp" class="control-label">Giờ hiện tại:</label>
                <input asp-for="TimeStamp" id="currentTime" class="form-control" readonly />
            </div>
            <div class="form-group">
                <label asp-for="Total" class="control-label">Tổng tiền</label>
                <input id="sum" name="Total" class="form-control"  readonly />
       
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>



@*pop up của supplier*@
        <div id="supplierPopup" style="display:none;
            position:fixed;
            top:0;
            left:0;
            width:100%;
            height:100%;
            background:rgba(0,0,0,0.5);
            z-index:9999;">

            <div style="background:white;
                width:400px;
                padding:20px;
                margin:100px auto;
                border-radius:10px;">

                <h4>Thêm Supplier</h4>

                <div class="form-group">
                    <label>Mã NCC</label>
                    <input id="newSupplierID" class="form-control" />
                </div>

                <div class="form-group mt-2">
                    <label>Tên NCC</label>
                    <input id="newSupplierName" class="form-control" />
                </div>

                <div class="mt-3 d-flex gap-2">

                    <button class="btn btn-primary" onclick="saveSupplier()">
                        Lưu
                    </button>

                    <button class="btn btn-secondary" onclick="closeSupplierPopup()">
                        Hủy
                    </button>

                </div>

            </div>
        </div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
<script>
    let oldData = @Html.Raw(
    System.Text.Json.JsonSerializer.Serialize(Model?.Goods ?? new List<ReceiptDetails> ())
);
let index = 0;
function addGoodRow(p = null){
    let container = document.getElementById("goodContainer");
    
    let row = document.createElement("div");
    row.classList.add("good-row");

    row.innerHTML = `
        <hr>

        <div class="form-group">
            <label>Good</label>
            <select class="form-control"
                    name="Goods[${index}].Device_ID"
                    onchange="fillProduct(this, ${index})">
               @foreach (var item in (ViewBag.Device as List<Device> ?? new List<Device>()))
                {
                    <option value="@item.Device_ID" data-price="@item.Cost.ToString()">@item.DeviceName</option>
                }
            </select>
        </div>

        <div class="form-group">
            <label>Good ID</label>
            <input id="gid_${index}"
                   class="form-control"
                   readonly />
        </div>

        <div class="form-group">
            <label>Type</label>
            <input id="type_${index}"
                   name="Goods[${index}].Type_ID"
                   type="text"
                   class="form-control"
                   readonly />
        </div>

        <div class="form-group">
            <label>Quantity</label>
            <input id="qty_${index}"
                   name="Goods[${index}].Quantity"
                   type="number"
                   value="1"
                   class="form-control"
                   data-val="true" 
                   data-val-required="Nhập số lượng" 
                   data-val-range="Lớn hơn 0" 
                   data-val-range-min="1"
                   data-val-range-max="2147483647"
                   oninput="calcTotal(); $(this).valid();" />
            <span class="text-danger field-validation-valid" 
            data-valmsg-for="Goods[${index}].Quantity" 
            data-valmsg-replace="true"></span>
        </div>

        <div class="form-group">
            <label>Price</label>
            <input id="price_${index}"
                   name="Goods[${index}].Cost"
                   class="form-control"
                   readonly />
        </div>
        
        <div class="form-group">
            <label>Thành tiền</label>
            <input id="lineTotal_${index}"
                name="Goods[${index}].SumAll"
                class="form-control"
                readonly />
        </div>
         <div id="goodContainer">
                <button type="button" class="btn btn-success" onclick="addGoodRow()"> + </button>
            
        <button type="button" class="btn btn-danger" onclick="removeRow(this)">
            -
        </button>
        </div>
    `;

        container.appendChild(row);
        $('form').removeData("validator");
        $('form').removeData("unobtrusiveValidation");
        $.validator.unobtrusive.parse('form');

        // 🔥 gọi luôn sau khi DOM chắc chắn có
    let select = row.querySelector("select");

     if (p) {
    select.value = p.Device_ID;
    document.getElementById("qty_" + index).value = p.Quantity;
    document.getElementById("price_" + index).value = p.Cost;
    document.getElementById("gid_" + index).value = p.Device_ID;
    document.getElementById("lineTotal_" + index).value = p.SumAll;
    document.getElementById("type_" + index).value = p.Type_ID;

    }

    // 🔥 nếu không có thì auto fill
    else {
        fillProduct(select, index);
    }
    index++;

    calcTotal();
}
window.onload = function () {

    index = 0;

    if (oldData.length > 0) {

        oldData.forEach(p => addGoodRow(p));

    } else {

        addGoodRow();
    }
};

function removeRow(btn) {

    // lấy row chứa button
    let row = btn.closest(".good-row");

    // xóa row đó
    row.remove();

    // cập nhật lại tổng tiền
    calcTotal();

    // (quan trọng) nếu bạn dùng index để submit MVC
    reIndex();
}
function reIndex() {

    let rows = document.querySelectorAll(".good-row");

    rows.forEach((row, i) => {

        let select = row.querySelector("select");
        let qty = row.querySelector("[name$='.Quantity']");
        let price = row.querySelector("[name$='.Cost']");
        let gid = row.querySelector("[id^='gid_']");
        let lineTotal = row.querySelector("[name$='.SumAll']");
        let type = row.querySelector("[name$='.Type_ID']");

            lineTotal.name = `Goods[${i}].SumAll`;
            select.name = `Goods[${i}].Device_ID`;
            qty.name = `Goods[${i}].Quantity`;
            price.name = `Goods[${i}].Cost`;
            type.name = `Goods[${i}].Type_ID`;

        if (gid) gid.id = `gid_${i}`;
    });
}
function updateTime() {

    const now = new Date();

    document.getElementById("currentTime").value =
        now.getFullYear() + "-" +
        String(now.getMonth() + 1).padStart(2, '0') + "-" +
        String(now.getDate()).padStart(2, '0') + " " +
        String(now.getHours()).padStart(2, '0') + ":" +
        String(now.getMinutes()).padStart(2, '0') + ":" +
        String(now.getSeconds()).padStart(2, '0');
}

// init

updateTime();

setInterval(updateTime, 1000);
async function fillProduct(select, i) {

    
    let option = select.options[select.selectedIndex];

    let Device_Id = option.value;
    let price = parseFloat(option.dataset.price) || 0;

    document.getElementById("gid_" + i).value = Device_Id;
    document.getElementById("price_" + i).value = price;
    device_id= document.getElementById("gid_" + i).value;
    let response = await fetch('/Device/CreateAjax',{
        method: 'POST',
        headers:{
             'Content-Type': 'application/json'
        },
        body: JSON.stringify({
            Device_ID:device_id,
        })
    });
    let data = await response.json();
    if (data.success) {

        let device_type = document.getElementById("type_" + i);

        device_type.value = data.device_type;
    }
    else {

        alert(data.message);
    }
}
function calcTotal() {

    let rows = document.querySelectorAll(".good-row");

    let total = 0;

    rows.forEach(row => {

        let qtyInput = row.querySelector("[name$='.Quantity']");
        let priceInput = row.querySelector("[name$='.Cost']");
        let lineTotalInput = row.querySelector("[id^='lineTotal_']");
        let qty = parseFloat(qtyInput?.value) || 0;
        let price = parseFloat(priceInput?.value) || 0;
        let lineTotal = qty * price;

        // 👉 gán thành tiền từng dòng
        if (lineTotalInput) {
            lineTotalInput.value = lineTotal;
        }
        total += qty * price;
    });

    document.getElementById("sum").value = total;
}


function openSupplierPopup() {

    document.getElementById("supplierPopup").style.display = "block";
}

function closeSupplierPopup() {

    document.getElementById("supplierPopup").style.display = "none";
}


async function saveSupplier() {

    let supplierID = document.getElementById("newSupplierID").value;

    let supplierName = document.getElementById("newSupplierName").value;

    let response = await fetch('/Supplier/CreateAjax', {

        method: 'POST',

        headers: {
            'Content-Type': 'application/json'
        },

        body: JSON.stringify({
            SupplierID: supplierID,
            SupplierName: supplierName
        })
    });

    let data = await response.json();

    if (data.success) {

        let select = document.getElementById("supplierSelect");

        let option = document.createElement("option");

        option.value = data.supplierID;

        option.text = data.supplierName;

        option.selected = true;

        select.appendChild(option);

        select.value = data.supplierID;

        closeSupplierPopup();
    }
    else {

        alert(data.message);
    }
}
</script>